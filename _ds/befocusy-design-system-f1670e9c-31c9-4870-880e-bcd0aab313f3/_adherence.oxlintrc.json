{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "social/linkedin-ia-tier/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Poppins|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Poppins, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactModal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|key|ref|className|style|children)$/]",
        "message": "<ContactModal> doesn't accept that prop. Declared props: open, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:onContact|key|ref|className|style|children)$/]",
        "message": "<CtaBand> doesn't accept that prop. Declared props: onContact."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:onContact|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: onContact."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nav'] > JSXAttribute > JSXIdentifier[name!=/^(?:onContact|key|ref|className|style|children)$/]",
        "message": "<Nav> doesn't accept that prop. Declared props: onContact."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pricing'] > JSXAttribute > JSXIdentifier[name!=/^(?:onContact|key|ref|className|style|children)$/]",
        "message": "<Pricing> doesn't accept that prop. Declared props: onContact."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
